# GitHub App Credentials
GITHUB_APP_ID=123456
# Content of the GITHUB_PRIVATE_KEY (.pem) file. Surround with double quotes.
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret
GITHUB_ORG=faminas-ads

# GitHub App OAuth Credentials
GITHUB_OAUTH_CLIENT_ID=your_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_client_secret

# Database & Cache Connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/crivo?schema=public"
REDIS_URL="redis://localhost:6379"

# Security & App config
JWT_SECRET=your_super_secret_jwt_key
APP_BASE_URL=http://localhost:3000

# Predefined professors (comma-separated GitHub logins)
PROFESSOR_LOGINS=prof1,prof2

# Intervalo do repeatable job do congelador, em ms (padrão 60000).
# Lido apenas pelo processo do worker.
CONGELADOR_INTERVAL_MS=60000
